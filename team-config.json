    "fan_out_patterns": {
      "pre_merge": {
        "description": "Before merge: security + test coverage + quality gate",
        "agents": ["pi-security", "pi-test-coverage", "pi-quality-gate"],
        "type": "parallel",
        "merge_action": "orchestrator synthesizes → go/no-go"
      },
      "pre_build": {
        "description": "Before implementation: spec + architecture + PRD review",
        "agents": ["opencode-spec", "opencode-architect", "pi-pm-prd-review"],
        "type": "sequential",
        "merge_action": "spec gates architecture, architecture gates build"
      },
      "pm_review": {
        "description": "PM quality check before engineering handoff",
        "agents": ["pi-pm-prd-review", "pi-pm-strategy-check", "pi-pm-market-fit", "pi-pm-discovery-audit"],
        "type": "parallel",
        "merge_action": "orchestrator synthesizes → handoff or iterate"
      }
    }
